<Window x:Class="AnimeQuoteWall.GUI.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="About Anime Quote Wallpaper Manager"
        Width="520"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryColor}"
                Padding="24,28">
            <DockPanel>
                <Border DockPanel.Dock="Left"
                        Background="White"
                        CornerRadius="12"
                        Width="56" Height="56"
                        Margin="0,0,16,0">
                    <Image Source="../Resources/appicon.png"
                           Margin="8"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Anime Quote Wallpaper Manager"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock x:Name="VersionLine"
                               FontSize="13"
                               Foreground="White"
                               Opacity="0.85"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="28,20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock TextWrapping="Wrap"
                           FontSize="13"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,14">
                    Generate, organize, and apply anime-quote wallpapers on Windows. Supports
                    single and multi-monitor setups, animated wallpapers, scheduled rotations,
                    and a personal quote library. All user data stays on this machine.
                </TextBlock>

                <TextBlock Text="License"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,8,0,4"/>
                <TextBlock Text="MIT. See LICENSE for details."
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"
                           Margin="0,0,0,14"/>

                <TextBlock Text="Third-party components"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"
                           Margin="0,0,0,14">
                    MahApps.Metro.IconPacks (MIT), Magick.NET (Apache 2.0),
                    SixLabors.ImageSharp (Apache 2.0 / Six Labors Split License),
                    FFmpeg (LGPL 2.1+).
                </TextBlock>

                <TextBlock Text="Project links"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,8,0,8"/>
                <WrapPanel>
                    <Button Style="{StaticResource ModernSecondaryButton}"
                            Content="GitHub"
                            Margin="0,0,8,8"
                            Click="OpenGitHub_Click"/>
                    <Button Style="{StaticResource ModernSecondaryButton}"
                            Content="Report an issue"
                            Margin="0,0,8,8"
                            Click="OpenIssues_Click"/>
                    <Button Style="{StaticResource ModernSecondaryButton}"
                            Content="Releases"
                            Margin="0,0,8,8"
                            Click="OpenReleases_Click"/>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="28,14">
            <Button Style="{StaticResource ModernPrimaryButton}"
                    Content="Close"
                    MinWidth="100"
                    HorizontalAlignment="Right"
                    IsDefault="True"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </Border>
    </Grid>
</Window>
