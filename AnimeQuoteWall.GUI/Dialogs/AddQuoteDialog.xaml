<Window x:Class="AnimeQuoteWall.GUI.Dialogs.AddQuoteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Add new quote"
        Width="600"
        Height="520"
        MinWidth="480"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryColor}"
                Padding="24,20">
            <DockPanel>
                <Border DockPanel.Dock="Left"
                        Background="White"
                        CornerRadius="10"
                        Width="40" Height="40"
                        Margin="0,0,16,0">
                    <iconPacks:PackIconMaterial Kind="FormatQuoteOpen"
                                                Width="22" Height="22"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource PrimaryColor}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Add a new quote"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock Text="Quotes appear when generating wallpapers"
                               FontSize="12"
                               Foreground="White"
                               Opacity="0.85"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="28,24" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Quote text"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="QuoteTextBox"
                         Height="120"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Padding="12"
                         FontSize="14"
                         Background="{DynamicResource HoverBackground}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderColor}"
                         BorderThickness="1"
                         Margin="0,0,0,18"/>

                <TextBlock Text="Character name"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="CharacterTextBox"
                         Padding="12"
                         FontSize="14"
                         Background="{DynamicResource HoverBackground}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderColor}"
                         BorderThickness="1"
                         Margin="0,0,0,18"/>

                <TextBlock Text="Anime name (optional)"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="AnimeTextBox"
                         Padding="12"
                         FontSize="14"
                         Background="{DynamicResource HoverBackground}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderColor}"
                         BorderThickness="1"
                         Margin="0,0,0,6"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="28,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource ModernSecondaryButton}"
                        Content="Cancel"
                        MinWidth="100"
                        Margin="0,0,12,0"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
                <Button Style="{StaticResource ModernPrimaryButton}"
                        Content="Add quote"
                        MinWidth="130"
                        IsDefault="True"
                        Click="OkButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
