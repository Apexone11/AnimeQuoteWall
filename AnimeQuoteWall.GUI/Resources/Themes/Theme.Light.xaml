<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Light Theme Brushes -->
    <SolidColorBrush x:Key="WindowBackground"  Color="#F0F2F5"/>
    <SolidColorBrush x:Key="CardBackground"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryColor"      Color="#6366F1"/>
    <SolidColorBrush x:Key="PrimaryDark"       Color="#4F52E0"/>
    <SolidColorBrush x:Key="PrimaryLight"      Color="#818CF8"/>
    <SolidColorBrush x:Key="SuccessColor"      Color="#10B981"/>
    <SolidColorBrush x:Key="SuccessDark"       Color="#059669"/>
    <SolidColorBrush x:Key="DangerColor"       Color="#EF4444"/>
    <SolidColorBrush x:Key="DangerDark"        Color="#DC2626"/>
    <SolidColorBrush x:Key="WarningColor"      Color="#F59E0B"/>
    <SolidColorBrush x:Key="WarningDark"       Color="#D97706"/>
    <SolidColorBrush x:Key="SecondaryColor"    Color="#64748B"/>
    <SolidColorBrush x:Key="TextPrimary"       Color="#111827"/>
    <SolidColorBrush x:Key="TextSecondary"     Color="#6B7280"/>
    <SolidColorBrush x:Key="TextTertiary"      Color="#9CA3AF"/>
    <SolidColorBrush x:Key="BorderColor"       Color="#E4E7EC"/>
    <SolidColorBrush x:Key="HoverBackground"   Color="#EEF2FF"/>
    <SolidColorBrush x:Key="SidebarBackground" Color="#1E1B4B"/>
    <SolidColorBrush x:Key="SidebarText"       Color="#C7D2FE"/>
    <SolidColorBrush x:Key="SidebarAccent"     Color="#818CF8"/>
</ResourceDictionary>
