<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Brushes -->
    <SolidColorBrush x:Key="WindowBackground"  Color="#0D0F14"/>
    <SolidColorBrush x:Key="CardBackground"    Color="#161A23"/>
    <SolidColorBrush x:Key="PrimaryColor"      Color="#818CF8"/>
    <SolidColorBrush x:Key="PrimaryDark"       Color="#6366F1"/>
    <SolidColorBrush x:Key="PrimaryLight"      Color="#A5B4FC"/>
    <SolidColorBrush x:Key="SuccessColor"      Color="#34D399"/>
    <SolidColorBrush x:Key="SuccessDark"       Color="#10B981"/>
    <SolidColorBrush x:Key="DangerColor"       Color="#F87171"/>
    <SolidColorBrush x:Key="DangerDark"        Color="#EF4444"/>
    <SolidColorBrush x:Key="WarningColor"      Color="#FBBF24"/>
    <SolidColorBrush x:Key="WarningDark"       Color="#F59E0B"/>
    <SolidColorBrush x:Key="SecondaryColor"    Color="#9CA3AF"/>
    <SolidColorBrush x:Key="TextPrimary"       Color="#F9FAFB"/>
    <SolidColorBrush x:Key="TextSecondary"     Color="#9CA3AF"/>
    <SolidColorBrush x:Key="TextTertiary"      Color="#6B7280"/>
    <SolidColorBrush x:Key="BorderColor"       Color="#252C3B"/>
    <SolidColorBrush x:Key="HoverBackground"   Color="#1E2333"/>
    <SolidColorBrush x:Key="SidebarBackground" Color="#0A0C12"/>
    <SolidColorBrush x:Key="SidebarText"       Color="#A5B4FC"/>
    <SolidColorBrush x:Key="SidebarAccent"     Color="#818CF8"/>
</ResourceDictionary>
