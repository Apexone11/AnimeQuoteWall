<Window x:Class="AnimeQuoteWall.GUI.SimpleMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anime Quote Wallpaper Manager"
        Icon="Resources/appicon.ico"
        Height="750"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        x:Name="MainWindowElement"
        Background="#F5F7FA">

    <Window.Resources>
        <!-- Modern Color Palette -->
        <SolidColorBrush x:Key="WindowBackground" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="ContentBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E1E8ED"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1A202C"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#4A5568"/>
        <SolidColorBrush x:Key="TextTertiary" Color="#718096"/>
        <SolidColorBrush x:Key="ListItemBackground" Color="#F7FAFC"/>
        <SolidColorBrush x:Key="InputBackground" Color="#EDF2F7"/>
        <SolidColorBrush x:Key="ButtonPrimary" Color="#667EEA"/>
        <SolidColorBrush x:Key="ButtonPrimaryHover" Color="#5A67D8"/>
        <SolidColorBrush x:Key="ButtonSuccess" Color="#48BB78"/>
        <SolidColorBrush x:Key="ButtonSuccessHover" Color="#38A169"/>
        <SolidColorBrush x:Key="ButtonDanger" Color="#F56565"/>
        <SolidColorBrush x:Key="ButtonDangerHover" Color="#E53E3E"/>
        <SolidColorBrush x:Key="ButtonSecondary" Color="#718096"/>
        <SolidColorBrush x:Key="ButtonSecondaryHover" Color="#4A5568"/>
        <SolidColorBrush x:Key="AccentColor" Color="#667EEA"/>
        <SolidColorBrush x:Key="AccentGradientStart" Color="#667EEA"/>
        <SolidColorBrush x:Key="AccentGradientEnd" Color="#764BA2"/>

        <!-- Gradient Brushes -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667EEA" Offset="0"/>
            <GradientStop Color="#764BA2" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonPrimaryGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#667EEA" Offset="0"/>
            <GradientStop Color="#5A67D8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonSuccessGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#48BB78" Offset="0"/>
            <GradientStop Color="#38A169" Offset="1"/>
        </LinearGradientBrush>

        <!-- Shadow Effects -->
        <DropShadowEffect x:Key="CardShadow" Color="#1A000000" BlurRadius="20" ShadowDepth="4" Opacity="0.15"/>
        <DropShadowEffect x:Key="HeaderShadow" Color="#1A000000" BlurRadius="25" ShadowDepth="5" Opacity="0.2"/>
        <DropShadowEffect x:Key="ButtonShadow" Color="#1A000000" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonPrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#1A000000" BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Success Button Style -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource ButtonSuccessGradient}"/>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#F56565"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E53E3E"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#1A000000" BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CBD5E0"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern TabControl Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="8,8,0,0"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,5,0">
                            <ContentPresenter ContentSource="Header"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#667EEA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#EDF2F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Modern Header with Gradient -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderGradient}"
                Padding="25,20"
                Margin="0,0,0,25"
                CornerRadius="12"
                Effect="{StaticResource HeaderShadow}">
            <StackPanel Orientation="Horizontal">
                <Image Source="Resources/appicon.png"
                       Width="40"
                       Height="40"
                       Margin="0,0,18,0"
                       VerticalAlignment="Center"/>
                <TextBlock Text="Anime Quote Wallpaper Manager"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content Tabs -->
        <TabControl Grid.Row="1">

            <!-- Wallpaper Preview & Generation Tab -->
            <TabItem Header="🖼️ Wallpaper">
                <Grid Margin="25" Background="{StaticResource ContentBackground}" CornerRadius="12">
                    <Grid.Effect>
                        <DropShadowEffect Color="#1A000000" BlurRadius="20" ShadowDepth="4" Opacity="0.1"/>
                    </Grid.Effect>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Preview Section Header -->
                    <TextBlock Grid.Row="0"
                               Text="Preview"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,20"
                               Foreground="{StaticResource TextPrimary}"/>

                    <!-- Wallpaper Preview with Modern Card -->
                    <Border Grid.Row="1"
                            Background="#FAFAFA"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Margin="0,0,0,25"
                            Padding="2">
                        <Border Background="White" CornerRadius="10">
                            <Grid>
                                <Image x:Name="WallpaperPreview"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <Border x:Name="NoPreviewBorder"
                                        Background="#F7FAFC"
                                        CornerRadius="10"
                                        Visibility="Visible">
                                    <TextBlock x:Name="NoPreviewText"
                                               Text="No wallpaper generated yet. Click 'Generate New Wallpaper' to create one!"
                                               FontSize="15"
                                               Foreground="{StaticResource TextTertiary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               Margin="50"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button x:Name="GenerateButton"
                                Content="⚡ Generate New Wallpaper"
                                MinWidth="220"
                                Height="50"
                                Click="GenerateButton_Click"
                                Style="{StaticResource ModernButton}"
                                Margin="0,0,15,0"/>
                        <Button x:Name="RefreshButton"
                                Content="🔄 Refresh"
                                MinWidth="140"
                                Height="50"
                                Click="RefreshButton_Click"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,15,0"/>
                        <Button x:Name="ApplyButton"
                                Content="✨ Apply as Wallpaper"
                                MinWidth="200"
                                Height="50"
                                Click="ApplyButton_Click"
                                Style="{StaticResource SuccessButton}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Quotes Management Tab -->
            <TabItem Header="💬 Quotes">
                <Grid Margin="25" Background="{StaticResource ContentBackground}" CornerRadius="12">
                    <Grid.Effect>
                        <DropShadowEffect Color="#1A000000" BlurRadius="20" ShadowDepth="4" Opacity="0.1"/>
                    </Grid.Effect>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Quotes Header with Actions -->
                    <DockPanel Grid.Row="0"
                               Margin="0,0,0,20">
                        <TextBlock Text="Quote Library"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <Button x:Name="AddQuoteButton"
                                    Content="➕ Add Quote"
                                    MinWidth="140"
                                    Height="42"
                                    Click="AddQuoteButton_Click"
                                    Style="{StaticResource ModernButton}"
                                    Margin="0,0,12,0"/>
                            <Button x:Name="DeleteQuoteButton"
                                    Content="🗑️ Delete"
                                    MinWidth="120"
                                    Height="42"
                                    Click="DeleteQuoteButton_Click"
                                    Style="{StaticResource DangerButton}"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Quotes List with Modern ScrollViewer -->
                    <Border Grid.Row="1"
                            Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Margin="0,0,0,20"
                            Padding="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                            <ListBox x:Name="QuotesListBox"
                                     SelectionMode="Single"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="20"
                                                Background="{StaticResource ListItemBackground}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Effect="{StaticResource CardShadow}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Text}"
                                                           FontSize="15"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           LineHeight="24"
                                                           Margin="0,0,0,12"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="— "
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock Text="{Binding Character}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text=" ("
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextTertiary}"
                                                               Margin="6,0,0,0"/>
                                                    <TextBlock Text="{Binding Anime}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextTertiary}"/>
                                                    <TextBlock Text=")"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextTertiary}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Border>

                    <!-- Quote Count -->
                    <TextBlock Grid.Row="2"
                               x:Name="QuoteCountTextBottom"
                               FontSize="14"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextSecondary}"/>
                </Grid>
            </TabItem>

            <!-- Background Images Tab -->
            <TabItem Header="🌄 Backgrounds">
                <Grid Margin="25" Background="{StaticResource ContentBackground}" CornerRadius="12">
                    <Grid.Effect>
                        <DropShadowEffect Color="#1A000000" BlurRadius="20" ShadowDepth="4" Opacity="0.1"/>
                    </Grid.Effect>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Backgrounds Header -->
                    <DockPanel Grid.Row="0"
                               Margin="0,0,0,20">
                        <TextBlock Text="Background Images"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <Button x:Name="AddBackgroundButton"
                                    Content="➕ Add Images"
                                    MinWidth="150"
                                    Height="42"
                                    Click="AddBackgroundButton_Click"
                                    Style="{StaticResource ModernButton}"
                                    Margin="0,0,12,0"/>
                            <Button x:Name="DeleteBackgroundButton"
                                    Content="🗑️ Delete"
                                    MinWidth="120"
                                    Height="42"
                                    Click="DeleteBackgroundButton_Click"
                                    Style="{StaticResource DangerButton}"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Backgrounds List -->
                    <Border Grid.Row="1"
                            Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Margin="0,0,0,20"
                            Padding="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                            <ListBox x:Name="BackgroundsListBox"
                                     SelectionMode="Single"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Background="{StaticResource ListItemBackground}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Effect="{StaticResource CardShadow}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🖼️"
                                                           FontSize="18"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,14,0"/>
                                                <TextBlock Text="{Binding}"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           VerticalAlignment="Center"
                                                           FontWeight="Medium"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Border>

                    <!-- Background Count -->
                    <TextBlock Grid.Row="2"
                               x:Name="BackgroundCountText"
                               FontSize="14"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextSecondary}"/>
                </Grid>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="⚙️ Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="25" Background="{StaticResource ContentBackground}" CornerRadius="12">
                        <Grid.Effect>
                            <DropShadowEffect Color="#1A000000" BlurRadius="20" ShadowDepth="4" Opacity="0.1"/>
                        </Grid.Effect>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Theme Settings -->
                        <Border Grid.Row="0"
                                Background="White"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="25"
                                Margin="0,0,0,20"
                                CornerRadius="12"
                                Effect="{StaticResource CardShadow}">
                            <StackPanel>
                                <TextBlock Text="🎨 Appearance"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"
                                           Margin="0,0,0,20"/>

                                <CheckBox x:Name="DarkModeToggle"
                                          Content="Enable Dark Mode (Coming Soon)"
                                          FontSize="14"
                                          Foreground="{StaticResource TextSecondary}"
                                          Margin="0,0,0,12"
                                          IsEnabled="False"/>

                                <TextBlock Text="Changes will apply immediately"
                                           FontSize="12"
                                           Foreground="{StaticResource TextTertiary}"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- File Paths Settings -->
                        <Border Grid.Row="1"
                                Background="White"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="25"
                                Margin="0,0,0,20"
                                CornerRadius="12"
                                Effect="{StaticResource CardShadow}">
                            <StackPanel>
                                <TextBlock Text="📁 File Locations"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"
                                           Margin="0,0,0,20"/>

                                <!-- Backgrounds Path -->
                                <TextBlock Text="Backgrounds Folder:"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="BackgroundsPathTextBox"
                                             Grid.Column="0"
                                             IsReadOnly="True"
                                             Padding="12"
                                             Margin="0,0,12,0"
                                             Background="{StaticResource InputBackground}"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             BorderThickness="1"
                                             CornerRadius="8"
                                             FontSize="13"
                                             Foreground="{StaticResource TextPrimary}"/>
                                    <Button Grid.Column="1"
                                            Content="📂 Browse... (Coming Soon)"
                                            MinWidth="170"
                                            Height="40"
                                            FontSize="13"
                                            IsEnabled="False"
                                            Style="{StaticResource SecondaryButton}"/>
                                </Grid>

                                <!-- Quotes Path -->
                                <TextBlock Text="Quotes File:"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="QuotesPathTextBox"
                                             Grid.Column="0"
                                             IsReadOnly="True"
                                             Padding="12"
                                             Margin="0,0,12,0"
                                             Background="{StaticResource InputBackground}"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             BorderThickness="1"
                                             CornerRadius="8"
                                             FontSize="13"
                                             Foreground="{StaticResource TextPrimary}"/>
                                    <Button Grid.Column="1"
                                            Content="📄 Browse... (Coming Soon)"
                                            MinWidth="170"
                                            Height="40"
                                            FontSize="13"
                                            IsEnabled="False"
                                            Style="{StaticResource SecondaryButton}"/>
                                </Grid>

                                <Button Content="🔄 Reset to Defaults (Coming Soon)"
                                        MinWidth="250"
                                        Height="42"
                                        FontSize="13"
                                        IsEnabled="False"
                                        Style="{StaticResource SecondaryButton}"
                                        HorizontalAlignment="Left"/>

                                <Border Background="#FFF5E6"
                                        BorderBrush="#FFB84D"
                                        BorderThickness="1"
                                        Padding="12"
                                        CornerRadius="8"
                                        Margin="0,15,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠️"
                                                   FontSize="16"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Changing paths will restart the application"
                                                   FontSize="12"
                                                   Foreground="#E65100"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Information -->
                        <Border Grid.Row="2"
                                Background="#EBF8FF"
                                BorderBrush="#4299E1"
                                BorderThickness="1"
                                Padding="20"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="ℹ️ Default Locations"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="#2C5282"
                                           Margin="0,0,0,12"/>
                                <TextBlock x:Name="DefaultPathsInfo"
                                           FontSize="13"
                                           Foreground="#2C5282"
                                           TextWrapping="Wrap"
                                           LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
