<Window x:Class="AnimeQuoteWall.GUI.SimpleMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:AnimeQuoteWall.GUI.Pages"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Anime Quote Wallpaper Manager"
        Icon="Resources/appicon.ico"
        Height="820"
        Width="1240"
        MinHeight="640"
        MinWidth="920"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}"
        x:Name="MainWindowElement"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <!-- Sidebar Navigation Button -->
        <Style x:Key="SidebarNavButton" TargetType="Button">
            <Setter Property="Background"                Value="Transparent"/>
            <Setter Property="Foreground"                Value="{DynamicResource SidebarText}"/>
            <Setter Property="BorderThickness"           Value="0"/>
            <Setter Property="FontSize"                  Value="14"/>
            <Setter Property="FontWeight"                Value="Medium"/>
            <Setter Property="Height"                    Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                    Value="Hand"/>
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
            <Setter Property="TextOptions.TextRenderingMode"   Value="ClearType"/>
            <Setter Property="FocusVisualStyle"          Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="focusRing"
                                    Margin="6,2,6,2"
                                    CornerRadius="10"
                                    BorderBrush="{DynamicResource SidebarAccent}"
                                    BorderThickness="0"/>
                            <Border x:Name="accentBar"
                                    Width="4"
                                    HorizontalAlignment="Left"
                                    CornerRadius="0,4,4,0"
                                    Background="{DynamicResource SidebarAccent}"
                                    Visibility="Collapsed"/>
                            <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    Margin="6,2,6,2"
                                    Padding="14,0,14,0">
                                <ContentPresenter VerticalAlignment="Center"
                                                  RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource SidebarHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SidebarText_Hover}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="focusRing" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource SidebarHover}"/>
                                <Setter TargetName="accentBar" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="{DynamicResource SidebarText_Selected}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Section Separator -->
        <Style x:Key="SidebarSeparator" TargetType="Separator">
            <Setter Property="Background"    Value="{DynamicResource SidebarBorder}"/>
            <Setter Property="Margin"        Value="16,8"/>
            <Setter Property="Height"        Value="1"/>
        </Style>

        <!-- ── Modern ListBox (transparent, used inside pages) ── -->
        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="240" MinWidth="64" MaxWidth="280"/>
            <ColumnDefinition Width="*" MinWidth="600"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource SidebarBorder}"
                BorderThickness="0,0,1,0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="16" ShadowDepth="2" Direction="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App Logo / Branding -->
                <Border Grid.Row="0" Padding="16,20,16,16">
                    <DockPanel>
                        <Border Background="{DynamicResource PrimaryDark}"
                                CornerRadius="12"
                                Width="40" Height="40"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                DockPanel.Dock="Left">
                            <Border.Effect>
                                <DropShadowEffect Color="#6366F1" Opacity="0.5" BlurRadius="10" ShadowDepth="0"/>
                            </Border.Effect>
                            <Image Source="Resources/appicon.png"
                                   Stretch="Uniform"
                                   Margin="6"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel x:Name="SidebarBrandText" VerticalAlignment="Center">
                            <TextBlock Text="Anime Quote"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SidebarBrandHeading}"
                                       TextOptions.TextRenderingMode="ClearType"/>
                            <TextBlock Text="Wallpaper Manager"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarTextMuted}"
                                       Margin="0,1,0,0"
                                       TextOptions.TextRenderingMode="ClearType"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Collapse Toggle -->
                <Button Grid.Row="1"
                        x:Name="SidebarCollapseButton"
                        Click="SidebarCollapseButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Height="32"
                        Cursor="Hand"
                        Margin="10,0,10,8"
                        ToolTip="Collapse or expand the sidebar"
                        AutomationProperties.Name="Toggle sidebar">
                    <Border Background="{DynamicResource SidebarItemHover}" CornerRadius="8" Padding="0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial x:Name="CollapseIcon"
                                                        Kind="ChevronLeft"
                                                        Width="16" Height="16"
                                                        Foreground="{DynamicResource SidebarTextMuted}"
                                                        VerticalAlignment="Center"/>
                            <TextBlock x:Name="CollapseLabel"
                                       Text="Collapse"
                                       FontSize="12"
                                       Foreground="{DynamicResource SidebarTextMuted}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       TextOptions.TextRenderingMode="ClearType"/>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- ── Navigation ── -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,4">

                        <!-- Group 1: Wallpaper tools -->
                        <TextBlock x:Name="NavGroupLabel1"
                                   Text="GENERATE"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SidebarSectionLabel}"
                                   Margin="22,8,0,4"
                                   TextOptions.TextRenderingMode="ClearType"/>

                        <Button x:Name="NavWallpaperButton"
                                Style="{StaticResource SidebarNavButton}"
                                Click="NavButton_Click"
                                Tag="Wallpaper"
                                ToolTip="Static Wallpaper Generator">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Image" Width="18" Height="18"
                                                            Margin="0,0,12,0" VerticalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock x:Name="NavWallpaperLabel" Text="Static Generator" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavAnimatedWallpapersButton"
                                Style="{StaticResource SidebarNavButton}"
                                Click="NavButton_Click"
                                Tag="AnimatedWallpapers"
                                ToolTip="Animated Wallpapers Library">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Filmstrip" Width="18" Height="18"
                                                            Margin="0,0,12,0" VerticalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock x:Name="NavAnimatedLabel" Text="Animated Library" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Separator Style="{StaticResource SidebarSeparator}"/>

                        <!-- Group 2: Library -->
                        <TextBlock x:Name="NavGroupLabel2"
                                   Text="LIBRARY"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SidebarSectionLabel}"
                                   Margin="22,0,0,4"
                                   TextOptions.TextRenderingMode="ClearType"/>

                        <Button x:Name="NavQuotesButton"
                                Style="{StaticResource SidebarNavButton}"
                                Click="NavButton_Click"
                                Tag="Quotes"
                                ToolTip="Manage Quotes">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="FormatQuoteClose" Width="18" Height="18"
                                                            Margin="0,0,12,0" VerticalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock x:Name="NavQuotesLabel" Text="Quotes" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavBackgroundsButton"
                                Style="{StaticResource SidebarNavButton}"
                                Click="NavButton_Click"
                                Tag="Backgrounds"
                                ToolTip="Image Library">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ImageMultiple" Width="18" Height="18"
                                                            Margin="0,0,12,0" VerticalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock x:Name="NavBackgroundsLabel" Text="Image Library" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Separator Style="{StaticResource SidebarSeparator}"/>

                        <!-- Group 3: History & Playlists -->
                        <TextBlock x:Name="NavGroupLabel3"
                                   Text="MANAGE"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SidebarSectionLabel}"
                                   Margin="22,0,0,4"
                                   TextOptions.TextRenderingMode="ClearType"/>

                        <Button x:Name="NavHistoryButton"
                                Style="{StaticResource SidebarNavButton}"
                                Click="NavButton_Click"
                                Tag="History"
                                ToolTip="Wallpaper History">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="History" Width="18" Height="18"
                                                            Margin="0,0,12,0" VerticalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock x:Name="NavHistoryLabel" Text="History" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavPlaylistsButton"
                                Style="{StaticResource SidebarNavButton}"
                                Click="NavButton_Click"
                                Tag="Playlists"
                                ToolTip="Playlists">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="PlaylistPlay" Width="18" Height="18"
                                                            Margin="0,0,12,0" VerticalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock x:Name="NavPlaylistsLabel" Text="Playlists" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Separator Style="{StaticResource SidebarSeparator}"/>

                        <Button x:Name="NavSettingsButton"
                                Style="{StaticResource SidebarNavButton}"
                                Click="NavButton_Click"
                                Tag="Settings"
                                ToolTip="Settings">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="CogOutline" Width="18" Height="18"
                                                            Margin="0,0,12,0" VerticalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock x:Name="NavSettingsLabel" Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="3"
                        Padding="16,12"
                        BorderBrush="{DynamicResource SidebarBorder}"
                        BorderThickness="0,1,0,0">
                    <StackPanel x:Name="SidebarFooter">
                        <TextBlock x:Name="VersionText"
                                   Text="Anime Quote Wall"
                                   FontSize="11"
                                   Foreground="{DynamicResource SidebarSectionLabel}"
                                   HorizontalAlignment="Center"
                                   TextOptions.TextRenderingMode="ClearType"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════
             MAIN CONTENT AREA
        ════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,0,0,1"
                    Padding="24,14">
                <DockPanel>
                    <TextBlock x:Name="PageTitleText"
                               Text="Wallpaper"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               TextOptions.TextRenderingMode="ClearType"/>
                </DockPanel>
            </Border>

            <!-- Content Frame -->
            <Frame x:Name="ContentFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   JournalOwnership="OwnsJournal"
                   Background="{DynamicResource WindowBackground}"
                   LoadCompleted="ContentFrame_LoadCompleted"/>
        </Grid>
    </Grid>
</Window>
