<Page x:Class="AnimeQuoteWall.GUI.Pages.WallpaperPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Static Wallpaper Generator">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Grid Margin="24,20" SizeChanged="Page_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="300"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar Row ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16,10"
                Margin="0,0,0,16">
            <DockPanel>
                <!-- Left: Generate actions -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="GenerateButton"
                            MinWidth="160"
                            Height="40"
                            Click="GenerateButton_Click"
                            Style="{StaticResource ModernPrimaryButton}"
                            Padding="14,8"
                            ToolTip="Generate wallpaper for selected monitor">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FlashOutline" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Generate" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="GenerateAllMonitorsButton"
                            MinWidth="180"
                            Height="40"
                            Click="GenerateAllMonitorsButton_Click"
                            Style="{StaticResource ModernSuccessButton}"
                            Margin="8,0,0,0"
                            Padding="14,8"
                            ToolTip="Generate and apply a new wallpaper for every connected monitor">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Monitor" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="All Monitors" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="RefreshButton"
                            MinWidth="120"
                            Height="40"
                            Click="RefreshButton_Click"
                            Style="{StaticResource ModernSecondaryButton}"
                            Margin="8,0,0,0"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="RemoveGeneratedButton"
                            MinWidth="160"
                            Height="40"
                            Click="RemoveGeneratedButton_Click"
                            Style="{StaticResource ModernDangerButton}"
                            Margin="8,0,0,0"
                            Padding="12,8"
                            ToolTip="Remove the generated wallpaper and restore previous">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Remove" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right: Apply + Monitor selector + Zoom -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <!-- Zoom controls -->
                    <Button x:Name="ZoomOutButton" Width="36" Height="36" Click="ZoomOutButton_Click"
                            Style="{StaticResource ModernSecondaryButton}" ToolTip="Zoom Out" Padding="0">
                        <iconPacks:PackIconMaterial Kind="MagnifyMinusOutline" Width="16" Height="16"/>
                    </Button>
                    <TextBlock x:Name="ZoomLevelText" Text="100%" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"
                               Margin="6,0" MinWidth="38" TextAlignment="Center"/>
                    <Button x:Name="ZoomInButton" Width="36" Height="36" Click="ZoomInButton_Click"
                            Style="{StaticResource ModernSecondaryButton}" ToolTip="Zoom In" Padding="0">
                        <iconPacks:PackIconMaterial Kind="MagnifyPlusOutline" Width="16" Height="16"/>
                    </Button>
                    <Button x:Name="ZoomResetButton" Width="36" Height="36" Click="ZoomResetButton_Click"
                            Style="{StaticResource ModernSecondaryButton}" Margin="4,0,0,0" ToolTip="Reset Zoom" Padding="0">
                        <iconPacks:PackIconMaterial Kind="Restore" Width="16" Height="16"/>
                    </Button>
                    <Button x:Name="CompareButton" MinWidth="100" Height="36" Click="CompareButton_Click"
                            Style="{StaticResource ModernSecondaryButton}" Margin="8,0,0,0"
                            ToolTip="Compare with previous wallpaper" Padding="10,8">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Compare" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Compare" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="1" Height="28" Background="{DynamicResource BorderColor}" Margin="12,0"/>
                    <ComboBox x:Name="MonitorSelectionComboBox"
                              Width="190"
                              Height="36"
                              VerticalContentAlignment="Center"
                              FontSize="13"
                              Margin="0,0,8,0"
                              ToolTip="Select monitor(s) to apply wallpaper">
                        <ComboBoxItem Content="Use Settings Default" Tag="Default" IsSelected="True"/>
                    </ComboBox>
                    <Button x:Name="ApplyButton"
                            MinWidth="160"
                            Height="36"
                            Click="ApplyButton_Click"
                            Style="{StaticResource ModernSuccessButton}"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CheckCircleOutline" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Apply Wallpaper" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Spacer -->
                <Border/>
            </DockPanel>
        </Border>

        <!-- ── Multi-Monitor Preview Card ── -->
        <Border Grid.Row="1"
                Background="{DynamicResource HoverBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16"
                MinHeight="400">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="12" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <ScrollViewer x:Name="PreviewScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              PanningMode="Both"
                              MouseWheel="PreviewScrollViewer_MouseWheel"
                              SizeChanged="PreviewScrollViewer_SizeChanged">
                    <ItemsControl x:Name="MonitorPreviewsItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid x:Name="MonitorPreviewsGrid" Columns="2" Rows="0"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8"
                                        Background="{DynamicResource CardBackground}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="2"
                                        CornerRadius="12"
                                        Padding="12"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="MonitorPreview_MouseLeftButtonUp">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#818CF8"/>
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#6366F1" Opacity="0.25" BlurRadius="10" ShadowDepth="0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding MonitorName}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   Margin="0,0,0,8"
                                                   HorizontalAlignment="Center"
                                                   TextOptions.TextRenderingMode="ClearType"/>
                                        <Border Background="{DynamicResource HoverBackground}"
                                                BorderBrush="{DynamicResource BorderColor}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Height="220"
                                                ClipToBounds="True">
                                            <Image Source="{Binding PreviewImage}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <TextBlock Text="{Binding QuoteText}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="36"
                                                   Margin="0,6,0,0"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty state -->
                <Border x:Name="NoPreviewBorder"
                        Background="Transparent"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="PaletteOutline"
                                                    Width="56" Height="56"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,0,16"
                                                    Opacity="0.25"
                                                    Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock x:Name="NoPreviewText"
                                   Text="No wallpaper generated yet."
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextOptions.TextRenderingMode="ClearType"/>
                        <TextBlock Text="Click 'Generate' to create your first wallpaper"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Opacity="0.6"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Status Bar ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,8"
                Margin="0,10,0,0">
            <DockPanel>
                <TextBlock x:Name="LastGeneratedText"
                           Text="Ready"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"
                           TextOptions.TextRenderingMode="ClearType"/>
                <TextBlock x:Name="StatusText"
                           Text=""
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           TextOptions.TextRenderingMode="ClearType"/>
            </DockPanel>
        </Border>
    </Grid>
</Page>
